# Push backend URL (Cloudflare Worker). When set, the app uses Web Push (Level 2)
# instead of local setTimeout reminders. Leave empty for Level 1 (web-only) mode.
#
# Example: https://waqt-push.fwwz-id.workers.dev
VITE_PUSH_API_URL=https://waqt-push.fwwz-id.workers.dev

# Same Worker URL for the CLI test script (scripts/notification.ts).
PUSH_API_URL=https://waqt-push.fwwz-id.workers.dev

# Secret for `bun run notification "..."` — must match Worker secret:
#   cd worker && wrangler secret put TEST_PUSH_SECRET
TEST_PUSH_SECRET=
